{
  "name": "@fahlgren-mortine/hubspot-form-usability-enhancements",
  "version": "1.1.1",
  "type": "module",
  "description": "Enhanced HubSpot form usability, validation and styling with React hydration support",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/styles.css",
    "./theme-template": "./theme-template.css",
    "./docs/*": "./user-docs/*"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "theme-template.css",
    "user-docs/**/*"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:css && npm run build:types",
    "build:js": "rollup -c",
    "build:css": "postcss src/styles.css -o dist/styles.css",
    "build:types": "cp src/index.d.ts dist/index.d.ts",
    "dev": "nodemon --watch src --ext js,css --exec 'npm run build'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hubspot",
    "form-usability",
    "validation",
    "accessibility",
    "react"
  ],
  "author": "Fahlgren Mortine",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^1.0.0",
    "cssnano": "^7.1.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.0",
    "postcss-cli": "^11.0.0",
    "postcss-nested": "^7.0.2",
    "rollup": "^4.21.2",
    "typescript": "^5.6.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FahlgrenMortineDigital/hubspot-form-usability-enhancements.git"
  },
  "bugs": {
    "url": "https://github.com/FahlgrenMortineDigital/hubspot-form-usability-enhancements/issues"
  },
  "homepage": "https://github.com/FahlgrenMortineDigital/hubspot-form-usability-enhancements#readme"
}
